ENABLE_WEB_SEARCH=1
WEB_SEARCH_PROVIDER=auto

# Увімкни генеративний режим і заповни ключ/модель.
ENABLE_GENERATIVE_AI=1
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=your_model_here
OPENAI_BASE_URL=https://api.openai.com/v1


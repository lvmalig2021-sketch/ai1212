ENABLE_WEB_SEARCH=1
WEB_SEARCH_PROVIDER=auto

# Локальна генеративна модель через Ollama.
ENABLE_GENERATIVE_AI=1
GENERATIVE_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_KEEP_ALIVE=5m

# Налаштування генерації.
GENERATIVE_TIMEOUT=60
GENERATIVE_TEMPERATURE=0.45
GENERATIVE_MAX_TOKENS=900

# Якщо захочеш замість локальної моделі використовувати віддалений OpenAI-compatible API:
# GENERATIVE_PROVIDER=openai-compatible
# OPENAI_API_KEY=your_api_key_here
# OPENAI_MODEL=your_model_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# Опціонально для Google Custom Search:
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=
